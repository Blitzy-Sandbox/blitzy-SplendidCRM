{
  "name": "SplendidCRM",
  "version": "15.2.9366",
  "description": "SplendidCRM React Client",
  "author": "Paul Rony",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:cordova": "vite build --mode cordova",
    "build:android": "cordova build android",
    "build:androidRelease": "cordova build android --release --buildConfig=build.json",
    "build:ios": "cordova build ios",
    "configure:cordova": "cordova prepare",
    "configure:android": "cordova platform add android",
    "configure:ios": "cordova platform add ios",
    "start": "npm run dev",
    "start:android": "cordova run android --device",
    "start:ios": "cordova run ios --device"
  },
  "dependencies": {
    "@amcharts/amcharts4": "4.10.38",
    "@babel/standalone": "7.27.1",
    "@ckeditor/ckeditor5-build-classic": "^22.0.0",
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-regular-svg-icons": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@fortawesome/react-fontawesome": "0.2.2",
    "@microsoft/signalr": "10.0.0",
    "bootstrap": "5.3.6",
    "bpmn-js": "1.3.3",
    "bpmn-js-properties-panel": "0.13.1",
    "camunda-bpmn-moddle": "3.2.0",
    "ckeditor5-custom-build": "file:./ckeditor5-custom-build",
    "diagram-js": "2.6.1",
    "diagram-js-direct-editing": "1.6.4",
    "fast-xml-parser": "3.21.1",
    "framer-motion": "^11.0.0",
    "fullcalendar-reactwrapper": "^1.0.7",
    "history": "5.3.0",
    "idb": "8.0.1",
    "inherits": "2.0.4",
    "jquery": "3.7.1",
    "lodash": "4.17.23",
    "min-dom": "4.1.0",
    "mobx": "6.15.0",
    "mobx-react": "9.2.1",
    "mobx-react-router": "5.0.3",
    "moment": "2.30.1",
    "process": "0.11.10",
    "query-string": "9.1.1",
    "react": "19.1.0",
    "react-autocomplete": "^1.8.1",
    "react-big-calendar": "1.17.1",
    "react-bootstrap": "2.10.9",
    "react-bootstrap-table-next": "^4.0.3",
    "react-bootstrap-table2-paginator": "^2.0.7",
    "react-datetime": "3.2.0",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dnd-touch-backend": "16.0.1",
    "react-dom": "19.1.0",
    "react-router": "7.13.2",
    "react-select": "5.9.0",
    "react-signature-canvas": "1.0.7",
    "react-treeview": "^0.4.7"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.25.0",
    "@types/jquery": "^4.0.0",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.3",
    "@vitejs/plugin-react": "4.5.2",
    "cordova": "12.0.0",
    "cordova-android": "12.0.1",
    "cordova-ios": "7.0.1",
    "cordova-plugin-advanced-http": "3.3.1",
    "cordova-plugin-device": "2.1.0",
    "cordova-plugin-file": "8.0.1",
    "cordova-plugin-splashscreen": "6.0.2",
    "cordova-plugin-whitelist": "^1.3.5",
    "sass": "1.89.0",
    "typescript": "5.8.3",
    "vite": "6.4.1"
  },
  "overrides": {
    "bpmn-js-properties-panel": {
      "bpmn-js": "$bpmn-js",
      "diagram-js": "$diagram-js"
    },
    "mobx-react-router": {
      "react-router": "$react-router"
    },
    "react-autocomplete": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-big-calendar": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-bootstrap-table-next": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-bootstrap-table2-paginator": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-datetime": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-treeview": {
      "react": "$react"
    },
    "fullcalendar-reactwrapper": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-whitelist": {},
      "cordova-plugin-device": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-advanced-http": {},
      "cordova-plugin-file": {}
    }
  }
}
