{
    "compilerOptions": {
        "outDir": "./dist/",
        "sourceMap": true,
        "noImplicitAny": false,
        "module": "ESNext",
        "target": "ES2015",
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "lib": ["esnext", "dom"],
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": [
        "./src/**/*",
        "vite.config.ts"
    ],
    "exclude": [
        "./node_modules/**/*",
        "./_sgbak/**/*",
        "./src/components/_sgbak/**/*",
        "./src/views/_sgbak/**/*",
        "./src/scripts/_sgbak/**/*",
        "./src/EditComponents/_sgbak/**/*",
        "./src/DetailComponents/_sgbak/**/*",
        "./src/GridComponents/_sgbak/**/*"
    ]
}
