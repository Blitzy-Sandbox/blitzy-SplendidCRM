{
  "ConnectionStrings": {
    "SplendidCRM": "data source=(local)\\SplendidCRM;initial catalog=SplendidCRM;Integrated Security=true;TrustServerCertificate=true"
  },

  "SplendidCRM": {
    "SplendidProvider": "Microsoft.Data.SqlClient"
  },

  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:5000,https://localhost:5001"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "DetailedErrors": true
}
